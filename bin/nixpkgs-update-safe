#!/usr/bin/env bash
#
# nixpkgs-update-safe - Safely update Nix flake inputs with automatic rollback
#
# Updates nixpkgs and home-manager inputs, applies with home-manager switch,
# and commits with appropriate date information. Rolls back on failure.
#
# Usage:
#   ./bin/nixpkgs-update-safe              # Update both nixpkgs and home-manager
#   ./bin/nixpkgs-update-safe --nixpkgs-only  # Update only nixpkgs
#   just nix-update-safe
#

set -euo pipefail

# --- Configuration ---
SKIP_LIST_FILE=".nix-skip-commits"

# --- Argument parsing ---
NIXPKGS_ONLY=false
[[ "${1:-}" == "--nixpkgs-only" ]] && NIXPKGS_ONLY=true

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# --- Output helpers ---
print_status()  { echo -e "${GREEN}[INFO]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }
print_error()   { echo -e "${RED}[ERROR]${NC} $1"; }

# --- Run a command with single-line progress display ---
# Shows the latest output line in-place, captures full output in ERROR_LOG.
# Returns the command's exit code.
run_with_progress() {
    local label=$1
    shift
    print_status "$label"
    local cols cmd_log
    cols=$(($(tput cols 2>/dev/null || echo 80) - 4))
    cmd_log=$(mktemp -t nixpkgs-update-safe-cmd.XXXXXX)
    # Disable errexit so the pipeline failure doesn't exit the function before
    # we can capture PIPESTATUS and display the error. Save and restore the
    # original option state so an abnormal function exit doesn't leave set -e
    # disabled for the rest of the script.
    local old_errexit
    old_errexit=$(set +o | grep '^set [+-]o errexit$')
    set +e
    "$@" 2>&1 | tee "$cmd_log" | while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        printf '\r\033[K  %s' "${line:0:$cols}"
    done
    local -a pipe_status=("${PIPESTATUS[@]}")
    local rc=${pipe_status[0]}
    for p in "${pipe_status[@]}"; do
        if [[ $p -ne 0 ]]; then
            rc=$p
            break
        fi
    done
    # Keep the full output for later date extraction / inspection.
    # Do this while errexit is still disabled so a disk-full append does not
    # trigger a second rollback mid-cleanup.
    cat "$cmd_log" >> "$ERROR_LOG"
    eval "$old_errexit"
    printf '\r\033[K'
    if [[ $rc -ne 0 ]]; then
        echo
        print_error "Command failed (exit $rc). Last output:"
        if [[ -s "$cmd_log" ]]; then
            (grep -v '^$' "$cmd_log" | tail -5 | while IFS= read -r line; do
                echo -e "  ${RED}>${NC} $line"
            done) || true
        else
            echo -e "  ${RED}>${NC} (no output captured)"
        fi
    fi
    rm -f "$cmd_log"
    return $rc
}

# --- Date formatting (macOS compatible) ---
format_date() {
    local raw=$1
    [[ -z "$raw" || "$raw" == "null" ]] && { date +"%Y-%m-%d"; return; }
    date -d "$raw" +"%Y-%m-%d" 2>/dev/null \
        || date -j -f "%Y-%m-%dT%H:%M:%SZ" "$raw" +"%Y-%m-%d" 2>/dev/null \
        || echo "${raw:0:10}"
}

# --- Extract date from nix flake update output ---
# Parses lines like: • Updated input 'nixpkgs': '...' (2024-01-15) → '...' (2024-01-20)
# Returns the NEW date (the one after →)
extract_update_date() {
    local input_name=$1
    # Match the input name, grab the last parenthesized date on the line
    # || true prevents grep's exit code 1 (no match) from triggering set -e
    grep -i "input '$input_name'" "$ERROR_LOG" 2>/dev/null \
        | grep -oE '\([0-9]{4}-[0-9]{2}-[0-9]{2}\)' \
        | tail -1 \
        | tr -d '()' \
        || true
}

# --- Resolve nixpkgs node (handles indirection) ---
get_nixpkgs_rev() {
    local file=$1
    local target
    target=$(jq -r '.nodes.root.inputs.nixpkgs // "nixpkgs"' "$file")
    jq -r ".nodes.\"$target\".locked.rev // empty" "$file"
}

# --- Cleanup helper ---
cleanup() {
    rm -f "$BACKUP_FILE" "$ERROR_LOG"
}

# --- Rollback on failure ---
rollback() {
    trap - ERR  # Prevent re-entry
    # Disable errexit so a failure in any rollback step does not abort the
    # rest of the rollback (e.g., missing backup, disk-full skip-list write).
    local old_errexit
    old_errexit=$(set +o | grep '^set [+-]o errexit$')
    set +e
    print_warning "Rolling back flake.lock..."

    # Restore the working-tree file and the git index first, before any
    # operations (like skip-list writes) that could fail and abort rollback.
    cp "$BACKUP_FILE" flake.lock
    git restore --staged flake.lock 2>/dev/null || true

    # Don't skip-list if failure was due to disk space
    local skip_add=0
    if [[ -f "$ERROR_LOG" ]] && grep -qi "no space left on device" "$ERROR_LOG" 2>/dev/null; then
        skip_add=1
        print_warning "Detected 'no space left on device'; will not add nixpkgs rev to skip list"
    fi

    # Add problematic nixpkgs commit to skip list only if nixpkgs actually changed
    if [[ $skip_add -eq 0 && -n "${NEW_NIXPKGS_REV:-}" && "${NEW_NIXPKGS_REV:-}" != "null" && "${NEW_NIXPKGS_REV:-}" != "${OLD_NIXPKGS_REV:-}" ]]; then
        if ! grep -q "^$NEW_NIXPKGS_REV$" "$SKIP_LIST_FILE" 2>/dev/null; then
            echo "$NEW_NIXPKGS_REV" >> "$SKIP_LIST_FILE"
            print_warning "Added problematic nixpkgs commit to skip list: $NEW_NIXPKGS_REV"
        fi
    fi

    print_warning "Running hm-switch to restore previous configuration..."
    if just hm-switch; then
        print_status "Successfully restored previous configuration"
    else
        print_error "Failed to restore previous configuration with hm-switch"
        print_error "You may need to manually run 'just hm-switch' to fix your system"
    fi

    rm -f "$BACKUP_FILE"
    # Keep ERROR_LOG around for inspection
    if [[ -s "$ERROR_LOG" ]]; then
        print_warning "Full error log: $ERROR_LOG"
    else
        rm -f "$ERROR_LOG"
    fi
    print_status "Rollback completed"
    eval "$old_errexit"
}

# --- Preflight checks ---
for check in \
    "git rev-parse --git-dir > /dev/null 2>&1 || { print_error 'Not in a git repository'; exit 1; }" \
    "[[ -f flake.lock ]] || { print_error 'flake.lock not found'; exit 1; }" \
    "git diff --quiet flake.lock 2>/dev/null || { print_error 'flake.lock has uncommitted changes'; exit 1; }" \
    "command -v just &>/dev/null || { print_error 'just not found'; exit 1; }"
do
    eval "$check"
done

# Check staged separately (inverted logic)
if ! git diff --cached --quiet flake.lock 2>/dev/null; then
    print_error "flake.lock is staged. Please unstage it first."
    exit 1
fi

# --- Setup ---
print_status "Starting safe Nix flake update..."

BACKUP_FILE="flake.lock.backup.$$"
cp flake.lock "$BACKUP_FILE"

touch "$SKIP_LIST_FILE"
ERROR_LOG=$(mktemp -t nixpkgs-update-safe.XXXXXX)

trap 'rollback; exit 1' ERR

# Get current revisions
OLD_NIXPKGS_REV=$(get_nixpkgs_rev "$BACKUP_FILE")
if [[ "$NIXPKGS_ONLY" != true ]]; then
    OLD_HM_REV=$(jq -r '.nodes."home-manager".locked.rev // empty' "$BACKUP_FILE") || {
        print_error "Failed to read home-manager revision from $BACKUP_FILE"
        exit 1
    }
else
    OLD_HM_REV=""
fi

# --- Update flake ---
if [[ "$NIXPKGS_ONLY" == true ]]; then
    if ! run_with_progress "Updating nixpkgs..." nix flake update nixpkgs; then
        print_error "nix flake update failed"
        trap - ERR
        rollback
        exit 1
    fi
else
    if ! run_with_progress "Updating flake inputs..." just nixpkgs-update-flake; then
        print_error "nixpkgs-update-flake failed"
        trap - ERR
        rollback
        exit 1
    fi
fi

# Check if anything changed
if git diff --quiet flake.lock 2>/dev/null; then
    print_status "flake.lock unchanged, nothing to do"
    cleanup
    trap - ERR
    exit 0
fi

print_status "flake.lock changed, proceeding with checks..."

# Get new revisions
NEW_NIXPKGS_REV=$(get_nixpkgs_rev flake.lock)
if [[ "$NIXPKGS_ONLY" != true ]]; then
    NEW_HM_REV=$(jq -r '.nodes."home-manager".locked.rev // empty' flake.lock) || {
        print_error "Failed to read home-manager revision from flake.lock"
        exit 1
    }
else
    NEW_HM_REV=""
fi

# Check skip list
if [[ -n "$NEW_NIXPKGS_REV" && "$NEW_NIXPKGS_REV" != "null" ]]; then
    if grep -q "^$NEW_NIXPKGS_REV$" "$SKIP_LIST_FILE" 2>/dev/null; then
        print_warning "Nixpkgs commit $NEW_NIXPKGS_REV is in skip list (known problematic)"
        cp "$BACKUP_FILE" flake.lock
        cleanup
        trap - ERR
        print_warning "Remove commit from $SKIP_LIST_FILE to retry."
        exit 0
    fi
fi

# --- Apply with home-manager switch ---
if ! run_with_progress "Running hm-switch..." just hm-switch; then
    print_error "hm-switch failed"
    trap - ERR
    rollback
    exit 1
fi

# --- Build commit message from nix output dates ---
NIXPKGS_CHANGED=0
HM_CHANGED=0
[[ "$OLD_NIXPKGS_REV" != "$NEW_NIXPKGS_REV" ]] && NIXPKGS_CHANGED=1
[[ "$NIXPKGS_ONLY" != true && "$OLD_HM_REV" != "$NEW_HM_REV" ]] && HM_CHANGED=1

parts=()
dates=()

if [[ $NIXPKGS_CHANGED -eq 1 ]]; then
    print_status "Nixpkgs updated: ${OLD_NIXPKGS_REV:0:8} → ${NEW_NIXPKGS_REV:0:8}"
    nix_date=$(extract_update_date "nixpkgs")
    dates+=("$(format_date "$nix_date")")
    parts+=("nixpkgs")
fi

if [[ $HM_CHANGED -eq 1 ]]; then
    print_status "Home-manager updated: ${OLD_HM_REV:0:8} → ${NEW_HM_REV:0:8}"
    hm_date=$(extract_update_date "home-manager")
    dates+=("$(format_date "$hm_date")")
    parts+=("home-manager")
fi

if [[ ${#parts[@]} -eq 0 ]]; then
    parts+=("flake.lock")
    dates+=("$(date +%Y-%m-%d)")
fi

# Join parts with " & " and dates with ", "
joined_parts=$(IFS='&'; echo "${parts[*]}" | sed 's/&/ \& /g')
joined_dates=$(IFS=','; echo "${dates[*]}" | sed 's/,/, /g')
COMMIT_MSG="nix: update ${joined_parts} (${joined_dates})"

print_status "Commit message: $COMMIT_MSG"

# --- Commit ---
git add flake.lock
git commit -m "$COMMIT_MSG"

cleanup
trap - ERR

print_status "✅ Successfully updated and committed flake.lock"
print_status "Commit: $(git rev-parse --short HEAD)"
