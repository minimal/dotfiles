services=(redis-server mongod mysqld git-dude cmd-key-happy bitlbee solr)

for serv in $services
do
    if (pgrep -f $serv > /dev/null); then
        echo $serv is up
    elif [ "$1" = "-a" ]; then
        echo $serv is down
    fi
done
