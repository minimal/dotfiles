#! /usr/local/bin/zsh

# for COLOR in RED GREEN YELLOW WHITE BLACK CYAN; do
# eval PR_$COLOR='%{$fg[${(L)COLOR}]%}'
#     eval PR_BRIGHT_$COLOR='%{$fg_bold[${(L)COLOR}]%}'
