#!/bin/bash
set -e

dir=$(zoxide query -l | fzf --header 'New tmux session' --preview 'eza -la --no-permissions --no-user {}' --height 40% --reverse)

if [ -n "$dir" ]; then
  session_name=$(basename "$dir")
  if [ -n "$TMUX" ]; then
    tmux new-session -d -s "$session_name" -c "$dir" && tmux switch-client -t "$session_name"
  else
    tmux new-session -s "$session_name" -c "$dir"
  fi
fi
